{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": [
				"^lint"
			],
			"outputs": []
		},
		"test": {
			"dependsOn": [
				"^test"
			],
			"outputs": []
		},
		"type-check": {
			"outputs": []
		},
		"test:unit": {
			"outputs": []
		},
		"clean": {
			"cache": false
		}
	}
}