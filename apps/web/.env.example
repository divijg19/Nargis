# Frontend environment example for local development
# Copy to .env.local and adjust values for your environment
NEXT_PUBLIC_API_PY_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
# If deploying separately ensure backend sets ALLOWED_ORIGINS to this origin

# Server-side Hugging Face Spaces control (never expose to browser)
HF_TOKEN=hf_xxxxxxxxx
HF_PY_SPACE=username/python-runtime
HF_GO_SPACE=username/go-gateway
PY_SPACE_URL=https://username-python-runtime.hf.space
GO_SPACE_URL=https://username-go-gateway.hf.space
