{
  "name": "@nargis/web",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js 15 frontend for Nargis - AI-powered productivity platform with task management, habit tracking, and Pomodoro timer",
  "keywords": [
    "ai",
    "productivity",
    "task-management",
    "habit-tracking",
    "pomodoro",
    "nextjs",
    "react",
    "typescript",
    "real-time"
  ],
  "author": {
    "name": "Divij Ganjoo",
    "email": "divijganjoo2003@gmail.com",
    "url": "https://github.com/divijg19"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run -c vitest.config.ts",
    "coverage": "vitest run -c vitest.config.ts --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "biome lint . --write",
    "format": "biome format . --write",
    "unsafe": "biome check . --write --unsafe"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
